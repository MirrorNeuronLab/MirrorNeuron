defmodule Test do
  def run do
    Application.put_env(:logger, :level, :warning)
    Application.put_env(:logger, :console, level: :warning)
    :logger.set_primary_config(:level, :warning)
    Application.ensure_all_started(:mirror_neuron)
    require Logger
    Logger.info("Info level")
  end
end
Test.run()
