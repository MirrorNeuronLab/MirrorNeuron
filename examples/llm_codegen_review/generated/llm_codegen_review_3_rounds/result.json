_report.py\",\n  \"candidate_code\": \"import argparse\\nimport json\\nimport sys\\n\\ndef build_report(records, low_stock_threshold=5):\\n    \\\"\\\"\\\"Builds an inventory report from a list of records.\\n\\n    Args:\\n        records (list): A list of inventory records, where each record is a dict\\n                        with 'sku', 'category', 'quantity', and 'price'.\\n        low_stock_threshold (int): The threshold for considering an item as low stock.\\n\\n    Returns:\\n        dict: A dictionary containing the report details.\\n\\n    Raises:\\n        ValueError: If a record is malformed or has incorrect data types.\\n    \\\"\\\"\\\"\\n    total_quantity = 0\\n    total_value = 0.0\\n    category_totals_dict = {}\\n    low_stock_skus = []\\n\\n    if not records:\\n        return {\\n            \\\"total_quantity\\\": 0,\\n            \\\"total_value\\\": 0.0,\\n            \\\"category_totals\\\": [],\\n            \\\"low_stock_skus\\\": []\\n        }\\n\\n    for i, record in enumerate(records):\\n        try:\\n            sku = record['sku']\\n            category = record['category']\\n            quantity = record['quantity']\\n            price = record['price']\\n\\n            if not isinstance(quantity, (int, float)) or quantity < 0:\\n                raise ValueError(f\\\"Record {i}: 'quantity' must be a non-negative number.\\\")\\n            if not isinstance(price, (int, float)) or price < 0:\\n                raise ValueError(f\\\"Record {i}: 'price' must be a non-negative number.\\\")\\n            if not isinstance(sku, str) or not sku:\\n                raise ValueError(f\\\"Record {i}: 'sku' must be a non-empty string.\\\")\\n            if not isinstance(category, str) or not category:\\n                raise ValueError(f\\\"Record {i}: 'category' must be a non-empty string.\\\")\\n\\n            total_quantity += quantity\\n            total_value += quantity * price\\n\\n            if category not in category_totals_dict:\\n                category_totals_dict[category] = 0\\n            category_totals_dict[category] += quantity\\n\\n            if quantity < low_stock_threshold:\\n                low_stock_skus.append(sku)\\n\\n        except KeyError as e:\\n            raise ValueError(f\\\"Record {i}: Missing key {e}.\\\") from e\\n        except TypeError as e:\\n            raise ValueError(f\\\"Record {i}: Incorrect type for a field. {e}\\\") from e\\n\\n    sorted_category_totals = [\\n        {\\\"category\\\": cat, \\\"quantity\\\": qty}\\n        for cat, qty in sorted(category_totals_dict.items())\\n    ]\\n\\n    sorted_low_stock_skus = sorted(low_stock_skus)\\n\\n    return {\\n        \\\"total_quantity\\\": total_quantity,\\n        \\\"total_value\\\": round(total_value, 2),\\n        \\\"category_totals\\\": sorted_category_totals,\\n        \\\"low_stock_skus\\\": sorted_low_stock_skus\\n    }\\n\\ndef main():\\n    parser = argparse.ArgumentParser(description=\\\"Generate an inventory report.\\\")\\n    parser.add_argument(\\n        \\\"--input\\\",\\n        help=\\\"Path to the input JSON file. Reads from stdin if omitted.\\\",\\n        type=argparse.FileType('r'),\\n        default=sys.stdin\\n    )\\n    parser.add_argument(\\n        \\\"--format\\\",\\n        choices=['text', 'json'],\\n        default='text',\\n        help=\\\"Output format (text or json).\\\"\\n    )\\n    parser.add_argument(\\n        \\\"--low-stock-threshold\\\",\\n        type=int,\\n        default=5,\\n        help=\\\"Threshold for low stock items.\\\"\\n    )\\n\\n    args = parser.parse_args()\\n\\n    records = []\\n    try:\\n        with args.input as f:\\n            try:\\n                records = json.load(f)\\n            except json.JSONDecodeError:\\n                print(\\\"Error: Invalid JSON input.\\\", file=sys.stderr)\\n                sys.exit(1)\\n    except Exception as e:\\n        print(f\\\"Error reading input: {e}\\\", file=sys.stderr)\\n        sys.exit(1)\\n\\n    if not isinstance(records, list):\\n        print(\\\"Error: Input must be a JSON array.\\\", file=sys.stderr)\\n        sys.exit(1)\\n\\n    try:\\n        report = build_report(records, args.low_stock_threshold)\\n    except ValueError as e:\\n        print(f\\\"Error processing records: {e}\\\", file=sys.stderr)\\n        sys.exit(1)\\n\\n    if args.format == 'json':\\n        print(json.dumps(report, indent=2))\\n    else:\\n        print(\\\"Inventory Report:\\\")\\n        print(f\\\"Total Quantity: {report['total_quantity']}\\\")\\n        print(f\\\"Total Value: ${report['total_value']:.2f}\\\")\\n        print(\\\"\\\\nCategory Totals:\\\")\\n        if report['category_totals']:\\n            for item in report['category_totals']:\\n                print(f\\\"  - {item['category']}: {item['quantity']}\\\")\\n        else:\\n            print(\\\"  None\\\")\\n        print(\\\"\\\\nLow Stock SKUs:\\\")\\n        if report['low_stock_skus']:\\n            for sku in report['low_stock_skus']:\\n                print(f\\\"  - {sku}\\\")\\n        else:\\n            print(\\\"  No low stock items.\\\")\\n\\nif __name__ == '__main__':\\n    main()\\n\",\n  \"summary\": \"The script successfully implements an inventory report CLI that reads from a file or stdin, supports JSON and text output formats, and handles low stock thresholds.\",\n  \"strengths\": [\n    \"The `build_report` function is a pure function as required, separating report generation logic from I/O and argument parsing.\",\n    \"Comprehensive error handling is implemented for JSON decoding, file reading, and data validation within records.\",\n    \"The script correctly uses `argparse` for command-line argument parsing, including support for stdin and custom file input.\",\n    \"The output formatting for both JSON and text modes is clear and adheres to the specified requirements.\"\n  ],\n  \"improvement_suggestions\": [\n    \"The `build_report` function should explicitly handl