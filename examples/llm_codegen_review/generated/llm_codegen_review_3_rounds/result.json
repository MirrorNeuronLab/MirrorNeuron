  choices=['text', 'json'],\\\\n        default='text',\\\\n        help=\\\\\\\"Output format (text or json).\\\\\\\"\\\\n    )\\\\n    parser.add_argument(\\\\n        \\\\\\\"--low-stock-threshold\\\\\\\",\\\\n        type=int,\\\\n        default=5,\\\\n        help=\\\\\\\"Threshold for low stock items.\\\\\\\"\\\\n    )\\\\n\\\\n    args = parser.parse_args()\\\\n\\\\n    records: List[Dict[str, Any]] = []\\\\n    try:\\\\n        # Use 'with' statement to ensure the file is closed properly\\\\n        with args.input as f:\\\\n            try:\\\\n                records = json.load(f)\\\\n            except json.JSONDecodeError:\\\\n                print(\\\\\\\"Error: Invalid JSON input.\\\\\\\", file=sys.stderr)\\\\n                sys.exit(1)\\\\n    except Exception as e:\\\\n        # Catching broader exceptions for file reading issues\\\\n        print(f\\\\\\\"Error reading input: {e}\\\\\\\", file=sys.stderr)\\\\n        sys.exit(1)\\\\n\\\\n    # build_report now handles non-list input, but this check provides an early exit.\\\\n    if not isinstance(records, list):\\\\n        print(\\\\\\\"Error: Input must be a JSON array.\\\\\\\", file=sys.stderr)\\\\n        sys.exit(1)\\\\n\\\\n    try:\\\\n        report = build_report(records, args.low_stock_threshold)\\\\n    except ValueError as e:\\\\n        print(f\\\\\\\"Error processing records: {e}\\\\\\\", file=sys.stderr)\\\\n        sys.exit(1)\\\\n\\\\n    if args.format == 'json':\\\\n        print(json.dumps(report, indent=2))\\\\n    else:\\\\n        print(\\\\\\\"Inventory Report:\\\\\\\")\\\\n        print(f\\\\\\\"Total Quantity: {report['total_quantity']}\\\\\\\")\\\\n        print(f\\\\\\\"Total Value: ${report['total_value']:.2f}\\\\\\\")\\\\n        print(\\\\\\\"\\\\\\\\nCategory Totals:\\\\\\\")\\\\n        if report['category_totals']:\\\\n            for item in report['category_totals']:\\\\n                print(f\\\\\\\"  - {item['category']}: {item['quantity']}\\\\\\\")\\\\n   